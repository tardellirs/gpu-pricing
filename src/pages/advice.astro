---
import "../styles/globals.css";
import { ThemeToggle } from "../components/ThemeToggle.tsx";
import { Github, ArrowLeft } from "lucide-react";
import offerings from "../data/offerings.json";
import providers from "../data/providers.json";
import { OfferingsFileSchema, ProvidersFileSchema } from "../data/schema";

const parsedOfferings = OfferingsFileSchema.parse(offerings);
const parsedProviders = ProvidersFileSchema.parse(providers);

const GH_URL = "https://github.com/tardellirs/gpu-pricing";

const collectedAt =
  parsedOfferings
    .map((o) => o.collected_at)
    .sort()
    .at(-1) ?? "—";

const providerMap = new Map(parsedProviders.map((p) => [p.id, p]));

// --- Curation rules ---
// 1. Exclude legacy architectures (Pascal, Volta, Turing consumer).
//    Turing T4 is kept (still actively used as an inference workhorse).
// 2. Salad's lineup beyond RTX 3090 is reported but rarely available at
//    the Medium priority tier we standardized on.
// 3. Novita's spot tier is rarely available in practice.
// 4. Vast.ai pricing is marketplace-volatile — listed cheapest live offer
//    is often 2–3× higher when you actually provision.
const LEGACY_RE =
  /^(GTX 10|GTX 16|RTX 20|Tesla P40|Tesla P100|Tesla V100|^V100$|P40$|P100$)/i;

function classifyArch(model: string): string {
  const m = model.toUpperCase();
  if (/(B200|B300|GB200|GB300)/.test(m)) return "Blackwell";
  if (/(H100|H200|GH200)/.test(m)) return "Hopper";
  if (
    /(L40|L4|RTX 40|RTX 50|RTX PRO 6000|RTX 6000 ADA|RTX 6000 PRO|RTX 5090|RTX 4090|ADA)/.test(
      m,
    )
  )
    return "Ada/Blackwell";
  if (
    /(A100|A40|A30|A10|A16|A6000|A5000|A4000|RTX 30|MI300|MI325|MI350|MI355)/.test(
      m,
    )
  )
    return "Ampere";
  if (/T4/.test(m)) return "Turing T4";
  return "—";
}

type Marker = "primary" | "secondary" | "warn" | null;

function markerFor(o: { provider_id: string; tier: string }): Marker {
  if (
    o.tier === "marketplace" ||
    o.tier === "prototyping" ||
    o.provider_id === "akash" ||
    o.provider_id === "spheron" ||
    o.provider_id === "thunder-compute"
  ) {
    return "warn";
  }
  return null;
}

const ranking = parsedOfferings
  .filter((o) => o.price_usd_hour > 0)
  .filter((o) => !LEGACY_RE.test(o.gpu_model))
  .filter(
    (o) =>
      !(
        o.provider_id === "salad" &&
        !["RTX 3090", "RTX 3090 Ti"].includes(o.gpu_model)
      ),
  )
  .filter((o) => !(o.provider_id === "novita" && o.is_spot))
  .filter((o) => o.provider_id !== "vast-ai")
  .map((o) => ({
    ...o,
    provider_name: providerMap.get(o.provider_id)?.name ?? o.provider_id,
    provider_color: providerMap.get(o.provider_id)?.color ?? "#666",
    arch: classifyArch(o.gpu_model),
    vram_per_dollar: o.vram_gb / o.price_usd_hour,
    marker: markerFor(o),
  }))
  .sort((a, b) => b.vram_per_dollar - a.vram_per_dollar)
  .slice(0, 30);

// IDs of rows we explicitly highlight in the table
const PRIMARY_IDS = new Set([
  "verda-rtx-a6000-spot",
  "dataoorts-nova-a100-sxm4-80gb-spot",
  "verda-a100-sxm-80gb-spot",
  "packet-ai-rtx-pro-6000-pcie-on-demand",
]);
const SECONDARY_IDS = new Set([
  "dataoorts-nova-rtx-pro-6000-spot",
  "verda-rtx-pro-6000-spot",
  "runpod-rtx-a5000-community",
]);

// User-verified options — confirmed working in practice. Surface them
// even if they fall outside the top-30 by raw VRAM/$ — empirical
// reliability beats theoretical efficiency.
const VERIFIED_IDS = new Set([
  "gpuhub-rtx-4090-48gb-on-demand",
  "salad-rtx-3090-ti-spot",
]);

type Verified = {
  id: string;
  gpu: string;
  vram: number;
  price: number;
  provider: string;
  tier: string;
  why: string;
};

const VERIFIED_PICKS: Verified[] = [
  {
    id: "gpuhub-rtx-4090-48gb-on-demand",
    gpu: "RTX 4090 (48 GB mod)",
    vram: 48,
    price: 0.46,
    provider: "GPUHub",
    tier: "on-demand",
    why: "The cheapest verified 48 GB on true on-demand. Modded 48 GB Ada/Blackwell GPU, ~104 VRAM/$. Not in the top 30 by raw VRAM/$, but on-demand availability + 48 GB sweet spot make it a strong production pick when interruption isn't acceptable and you don't want to pay Packet.ai's premium.",
  },
  {
    id: "salad-rtx-3090-ti-spot",
    gpu: "RTX 3090 Ti",
    vram: 24,
    price: 0.22,
    provider: "Salad",
    tier: "spot (Medium)",
    why: "24 GB Ampere consumer at $0.22/h, confirmed available in practice. ~109 VRAM/$ — just outside top 30, but Salad's Medium priority tier has been workable. Remember: vCPU/RAM billed separately at Salad.",
  },
];

type Pick = {
  rank: number;
  position: string;
  title: string;
  spec: string;
  why: string;
};

const PICKS: Pick[] = [
  {
    rank: 1,
    position: "🏆 #1 overall practical pick",
    title: "RTX A6000 48GB @ $0.17/h spot — Verda",
    spec: "282 VRAM/$ · Ampere · 48 GB · spot tier",
    why: "Fits Llama-3 70B Q4, SDXL with batch, LoRA training of mid-size models. Verda spot has historically low interruption rates compared to marketplaces. The best objective cost-benefit on the entire list once you discount unreachable prices.",
  },
  {
    rank: 2,
    position: "🥈 #2 — when the model is big",
    title: "A100 80GB @ $0.45/h spot — Dataoorts or Verda",
    spec: "178 VRAM/$ · Ampere · 80 GB · NVLink (SXM) · spot tier",
    why: "The standard ML research GPU. Mature ecosystem, fits Llama-70B FP16, supports BF16/FlashAttention out of the box. Same price at two reputable providers gives natural redundancy.",
  },
  {
    rank: 3,
    position: "🥉 #3 — when you can't accept interruption",
    title: "RTX 6000 Pro 96GB @ $0.66/h on-demand — Packet.ai",
    spec: "145 VRAM/$ · Ada/Blackwell · 96 GB · GDDR7 · true on-demand",
    why: "The only sub-$1/h path to 96 GB of VRAM that's actually on-demand (no spot, no marketplace, no virtualization). Pay-as-you-go with no minimum commitment. The pick when the workload absolutely cannot be preempted.",
  },
  {
    rank: 4,
    position: "#4 — high VRAM batch jobs that tolerate spot",
    title: "RTX PRO 6000 96GB @ $0.59/h spot — Verda or Dataoorts",
    spec: "163 VRAM/$ · Ada/Blackwell · 96 GB · GDDR7 · spot tier",
    why: "Same hardware as #3 but 11% cheaper if you accept preemption. Two providers means natural failover. Best for high-throughput inference batching or non-time-critical training.",
  },
  {
    rank: 5,
    position: "#5 — small-model dev and prototyping",
    title: "RTX A5000 24GB @ $0.16/h — RunPod Community",
    spec: "150 VRAM/$ · Ampere · 24 GB · Community tier",
    why: "24 GB fits Llama-3 8B / Mistral / Stable Diffusion comfortably in FP16. RunPod Community availability is historically high and the UX is the best among GPU-native clouds. The default for daily dev work.",
  },
];

const REMOVED_FROM_RANKING = [
  {
    label: "Legacy architectures",
    detail:
      "Pascal (GTX 10xx, P40, P100), Volta (V100), Turing consumer (GTX 16xx, RTX 20xx). Missing BF16/FP8, no FlashAttention, poor tokens-per-second per dollar despite cheap headline prices. Turing T4 (data center) is kept — it's still a current inference card.",
  },
  {
    label: "Salad's full lineup",
    detail:
      "Only RTX 3090 and RTX 3090 Ti are treated as reliably available at the Medium priority tier. Other Salad SKUs are listed on the page but availability varies enough that they distort cost-benefit math.",
  },
  {
    label: "Novita Spot tier",
    detail:
      "Novita's spot pricing is published but rarely materializes in practice. Novita on-demand is fine and is included in the ranking; only the spot rows are excluded here.",
  },
  {
    label: "Vast.ai entirely",
    detail:
      "Marketplace volatility — the displayed price is the cheapest live offer at snapshot time, and the actual provisioning price is commonly 2–3× higher. Hard to plan around.",
  },
];

const PITFALLS = [
  {
    provider: "Salad / Modal",
    warning:
      "vCPU and RAM are billed separately. The GPU-only price misleads — a typical pod adds ~$0.05/h for vCPU+RAM you'll actually attach.",
  },
  {
    provider: "Spheron / Akash / Vast.ai cheapest",
    warning:
      'Displayed numbers are "cheapest live offer" — can be 2–3× higher when you actually provision. Treat as floor, not target.',
  },
  {
    provider: "CoreWeave",
    warning:
      "Classic tier still has 1x SKUs, but new H100/H200 are sold only in 8x bundles. The cheapest H100 1x here is $4.25 on-demand.",
  },
  {
    provider: "Vultr",
    warning:
      "H100/A100/B200 are 8x bundles. 1x SKUs limited to A16, L40S, A40, A100 PCIe, GH200.",
  },
  {
    provider: "Dataoorts",
    warning:
      'Pricing is "dynamic" (DDRA) and refreshes every ~18h. Numbers can drift between snapshots.',
  },
  {
    provider: "Thunder Compute Prototyping",
    warning:
      "Cheap because the GPU is virtualized (GPU-over-IP). Performance varies — not for production.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="robots" content="noindex" />
    <meta
      name="description"
      content="Curated cost-benefit ranking of cloud GPU rentals across 21 providers, sorted by VRAM per dollar-hour."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>advice — gpu-pricing</title>

    <script is:inline>
      (function () {
        try {
          var pinned = localStorage.getItem("theme");
          if (pinned === "light" || pinned === "dark") {
            document.documentElement.setAttribute("data-theme", pinned);
            var meta = document.querySelector('meta[name="color-scheme"]');
            if (meta) meta.setAttribute("content", pinned);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen text-ink-100">
    <header
      class="sticky top-0 z-30 h-14 border-b border-wire bg-ink-950/85 backdrop-blur-md"
    >
      <div class="h-full px-4 md:px-6 flex items-center justify-between gap-4">
        <a href="/" class="group flex items-center gap-2.5 min-w-0">
          <span class="text-accent text-base leading-none">▌</span>
          <span class="font-mono text-sm tracking-tight">
            <span class="text-ink-50 font-semibold">gpu-pricing</span>
            <span class="text-ink-500">/</span>
            <span
              class="text-ink-300 group-hover:text-ink-100 transition-colors"
              >advice</span
            >
          </span>
        </a>

        <div
          class="flex items-center gap-4 text-[10px] uppercase tracking-[0.16em] font-mono text-ink-400"
        >
          <a
            href="/"
            class="inline-flex items-center gap-1.5 hover:text-accent transition-colors"
          >
            <ArrowLeft className="w-3 h-3" />
            <span class="hidden sm:inline">back_to_catalog</span>
          </a>
          <ThemeToggle client:load />
          <a
            href={GH_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 hover:text-accent transition-colors"
          >
            <Github className="w-3.5 h-3.5" />
          </a>
        </div>
      </div>
      <div
        class="absolute left-0 right-0 -bottom-px h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"
      >
      </div>
    </header>

    <main
      class="max-w-4xl mx-auto px-4 md:px-6 py-10 md:py-16 space-y-12"
    >
      <!-- Intro -->
      <section class="space-y-4">
        <p class="text-[11px] uppercase tracking-[0.22em] text-ink-400 font-mono">
          <span class="text-accent">$</span> cat advice.md
        </p>
        <h1 class="text-3xl md:text-4xl font-mono font-semibold text-ink-50 leading-tight">
          The opinionated <span class="text-accent">cost-benefit</span> ranking.
        </h1>
        <p class="text-sm text-ink-200 font-sans leading-relaxed max-w-2xl">
          Ranked by <strong>VRAM per dollar-hour</strong>
          (<code>vram_gb ÷ price_usd_hour</code>) — the practical metric for ML
          workloads, where memory is the binding constraint and dollars
          determine how long you can run. Computed live from <code
            >offerings.json</code
          >, snapshot <span class="text-ink-100 tabular-nums">{collectedAt}</span>.
          Filtered to remove options that aren't realistically usable today:
          see <a href="#what-was-removed" class="text-accent hover:underline"
            >what was removed</a
          > below.
        </p>
      </section>

      <!-- Top 5 picks -->
      <section class="space-y-6">
        <h2
          class="text-[11px] uppercase tracking-[0.22em] text-ink-300 font-mono border-b border-wire pb-2"
        >
          <span class="text-accent">$</span> top_5_practical_picks
        </h2>

        <div class="space-y-4">
          {
            PICKS.map((p) => (
              <article class="border border-wire bg-ink-950/40 p-5 md:p-6 space-y-2">
                <div class="text-[10px] uppercase tracking-[0.18em] text-ink-400 font-mono">
                  {p.position}
                </div>
                <h3 class="text-lg md:text-xl font-mono text-ink-50">
                  <span class="text-accent">{p.title}</span>
                </h3>
                <div class="text-[11px] uppercase tracking-wider text-ink-300 font-mono">
                  {p.spec}
                </div>
                <p class="text-sm text-ink-200 font-sans leading-relaxed pt-1">
                  {p.why}
                </p>
              </article>
            ))
          }
        </div>
      </section>

      <!-- User-verified picks -->
      <section class="space-y-4">
        <h2
          class="text-[11px] uppercase tracking-[0.22em] text-ink-300 font-mono border-b border-wire pb-2"
        >
          <span class="text-accent">$</span> ✓ user_verified
        </h2>

        <p class="text-xs text-ink-300 font-sans leading-relaxed">
          Options confirmed working in practice — not necessarily top of the
          VRAM/$ leaderboard, but availability is verified. Empirical
          reliability beats theoretical efficiency.
        </p>

        <div class="grid md:grid-cols-2 gap-3">
          {
            VERIFIED_PICKS.map((v) => (
              <article class="border border-wireStrong bg-ink-900/40 p-4 space-y-2">
                <div class="flex items-center gap-2">
                  <span
                    class="text-accent text-sm font-mono"
                    title="User-verified"
                  >
                    ✓
                  </span>
                  <span class="text-sm font-mono text-ink-50 font-medium">
                    {v.gpu}
                  </span>
                </div>
                <div class="text-[11px] uppercase tracking-wider text-ink-400 font-mono flex flex-wrap gap-x-3 gap-y-1">
                  <span class="text-ink-200">{v.vram} GB</span>
                  <span class="text-ink-200">${v.price.toFixed(2)}/h</span>
                  <span>{v.provider}</span>
                  <span>{v.tier}</span>
                </div>
                <p class="text-xs text-ink-300 font-sans leading-relaxed pt-1">
                  {v.why}
                </p>
              </article>
            ))
          }
        </div>
      </section>

      <!-- Top 30 ranking -->
      <section class="space-y-4">
        <h2
          class="text-[11px] uppercase tracking-[0.22em] text-ink-300 font-mono border-b border-wire pb-2"
        >
          <span class="text-accent">$</span> top_30 — vram per $/hour
        </h2>

        <div class="overflow-x-auto border border-wire">
          <table class="w-full border-collapse">
            <thead class="bg-ink-900/80">
              <tr class="border-b border-wireStrong text-[10px] uppercase tracking-[0.16em] text-ink-400">
                <th class="text-left px-3 py-2.5 font-mono font-normal w-10">#</th>
                <th class="text-right px-3 py-2.5 font-mono font-normal">VRAM/$</th>
                <th class="text-left px-3 py-2.5 font-mono font-normal">GPU</th>
                <th class="text-right px-3 py-2.5 font-mono font-normal">VRAM</th>
                <th class="text-right px-3 py-2.5 font-mono font-normal">$/h</th>
                <th class="text-left px-3 py-2.5 font-mono font-normal">Provider</th>
                <th class="text-left px-3 py-2.5 font-mono font-normal hidden md:table-cell">Tier</th>
                <th class="text-left px-3 py-2.5 font-mono font-normal hidden lg:table-cell">Arch</th>
              </tr>
            </thead>
            <tbody>
              {
                ranking.map((r, i) => {
                  const rank = i + 1;
                  const highlighted = PRIMARY_IDS.has(r.id)
                    ? "primary"
                    : SECONDARY_IDS.has(r.id)
                      ? "secondary"
                      : null;
                  const rowClass = highlighted
                    ? "bg-accent/[0.06] border-l-2 border-l-accent"
                    : r.marker === "warn"
                      ? "opacity-80"
                      : "";
                  return (
                    <tr class={`border-b border-wire text-xs ${rowClass}`}>
                      <td class="px-3 py-2.5 font-mono text-ink-500 tabular-nums">
                        {String(rank).padStart(2, "0")}
                      </td>
                      <td class="px-3 py-2.5 font-mono text-right tabular-nums text-ink-50 font-semibold">
                        {Math.round(r.vram_per_dollar)}
                      </td>
                      <td class="px-3 py-2.5 font-mono text-ink-100">
                        <span class="inline-flex items-center gap-2">
                          <span
                            class="w-1 h-3 shrink-0"
                            style={`background:${r.gpu_brand === "NVIDIA" ? "#76b900" : "#ed1c24"}`}
                          />
                          {r.gpu_model}
                          {highlighted === "primary" && (
                            <span class="text-accent text-[10px]">★★</span>
                          )}
                          {highlighted === "secondary" && (
                            <span class="text-accent text-[10px]">★</span>
                          )}
                          {VERIFIED_IDS.has(r.id) && (
                            <span
                              class="text-accent text-[10px]"
                              title="User-verified working"
                            >
                              ✓
                            </span>
                          )}
                          {r.marker === "warn" && (
                            <span
                              class="text-ink-400 text-[10px]"
                              title="Marketplace or virtualized — listed price may not be the price you actually get"
                            >
                              ⚠
                            </span>
                          )}
                        </span>
                      </td>
                      <td class="px-3 py-2.5 font-mono text-right tabular-nums text-ink-200">
                        {r.vram_gb}
                        <span class="text-ink-400 text-[10px] ml-0.5">GB</span>
                      </td>
                      <td class="px-3 py-2.5 font-mono text-right tabular-nums text-ink-100">
                        <span class="text-ink-400">$</span>
                        {r.price_usd_hour.toFixed(2)}
                      </td>
                      <td class="px-3 py-2.5">
                        <a
                          href={providerMap.get(r.provider_id)?.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center gap-2 font-mono text-ink-100 hover:text-accent transition-colors"
                        >
                          <span
                            class="w-1.5 h-1.5 shrink-0"
                            style={`background:${r.provider_color}`}
                          />
                          {r.provider_name}
                        </a>
                      </td>
                      <td class="px-3 py-2.5 hidden md:table-cell">
                        <span class="text-[10px] uppercase tracking-wider text-ink-300 font-mono">
                          {r.tier}
                          {r.is_spot && r.tier !== "spot" ? " (spot)" : ""}
                        </span>
                      </td>
                      <td class="px-3 py-2.5 hidden lg:table-cell font-mono text-[11px] text-ink-300">
                        {r.arch}
                      </td>
                    </tr>
                  );
                })
              }
            </tbody>
          </table>
        </div>

        <p class="text-[11px] text-ink-400 font-mono leading-relaxed pt-1">
          <span class="text-accent">▸</span> ★★ = primary recommendation · ★ = strong alternative · ✓ = user-verified working · ⚠ = marketplace / virtualized (listed price may not materialize)
          <br />
          <span class="text-accent">▸</span> Honorable mentions just below the cutoff: Salad RTX 3090 ($0.20, 120 VRAM/$), Salad RTX 3090 Ti ($0.22, 109 ✓ verified), GPUHub RTX 4090 48GB ($0.46, 104 ✓ verified).
        </p>
      </section>

      <!-- What was removed -->
      <section class="space-y-4" id="what-was-removed">
        <h2
          class="text-[11px] uppercase tracking-[0.22em] text-ink-300 font-mono border-b border-wire pb-2"
        >
          <span class="text-accent">$</span> grep -v from_ranking
        </h2>

        <p class="text-sm text-ink-200 font-sans leading-relaxed">
          The ranking above filters out offerings that exist in the catalog but
          don't behave as advertised in real-world use. They remain visible on
          the <a href="/" class="text-accent hover:underline">catalog page</a> for
          completeness, with caveats attached.
        </p>

        <ul class="space-y-3">
          {
            REMOVED_FROM_RANKING.map((r) => (
              <li class="border-l-2 border-wireStrong pl-4 space-y-1">
                <div class="text-sm font-mono text-ink-100 font-medium">
                  {r.label}
                </div>
                <p class="text-xs text-ink-300 font-sans leading-relaxed">
                  {r.detail}
                </p>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Pitfalls -->
      <section class="space-y-4">
        <h2
          class="text-[11px] uppercase tracking-[0.22em] text-ink-300 font-mono border-b border-wire pb-2"
        >
          <span class="text-accent">$</span> cat pitfalls
        </h2>
        <ul class="space-y-2.5 text-xs font-sans text-ink-200 leading-relaxed">
          {
            PITFALLS.map((p) => (
              <li class="flex gap-3">
                <span class="text-accent shrink-0 font-mono">!</span>
                <span>
                  <strong class="font-mono text-ink-100">{p.provider}:</strong>{" "}
                  {p.warning}
                </span>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Single pick -->
      <section class="space-y-4">
        <h2
          class="text-[11px] uppercase tracking-[0.22em] text-ink-300 font-mono border-b border-wire pb-2"
        >
          <span class="text-accent">$</span> if i had to pick one
        </h2>
        <div
          class="border border-wireStrong bg-ink-900/60 p-5 md:p-7 space-y-4"
        >
          <p class="text-sm text-ink-100 font-sans leading-relaxed">
            <strong class="text-accent font-mono">RTX A6000 48GB at $0.17/h spot on Verda</strong> — 48 GB is the current sweet spot of VRAM (fits nearly everything that matters: Llama-3 70B Q4, FLUX/SDXL with batch, mid-size LoRA training). $0.17/h is absurdly cheap for that hardware class. Verda's spot historically has reasonable preemption frequency (not as volatile as marketplaces) and the RTX A6000 (Ampere) supports BF16, FlashAttention, vLLM, and the rest of the modern stack.
          </p>
          <p class="text-sm text-ink-200 font-sans leading-relaxed">
            If your workload <strong>cannot be interrupted</strong>:
            <strong class="text-accent font-mono"
